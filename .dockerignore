playwright/.auth/

# Reports
allure-results/
allure-report/

# Environment & Secrets
.env
.env.*

# Git and IDE (Docker doesn't need your history or editor settings)
.git
.gitignore
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db